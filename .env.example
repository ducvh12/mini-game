# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres123
DB_NAME=wheel_minigame
DB_PORT=5432

# Application Configuration
APP_PORT=3000
NODE_ENV=production

# Admin Password
ADMIN_PASSWORD=admin123
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

